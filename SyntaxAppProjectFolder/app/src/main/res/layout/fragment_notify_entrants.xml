<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.NotifyEntrantsFragment">


    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5">

        <TextView
            android:id="@+id/headerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            android:alpha="0"
            android:fontFamily="serif"
            android:text="Notify entrants"
            android:textColor="#1A1A1A"
            android:textSize="40sp"
            android:textStyle="bold"
            tools:alpha="1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ScrollView
            android:id="@+id/scrollView"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/headerTitle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Send to card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/sendToCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="14dp"
                    android:alpha="0"
                    tools:alpha="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SEND TO"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="12dp" />

                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:columnCount="2"
                            android:rowCount="2"
                            android:useDefaultMargins="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipWaitlist"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_marginBottom="8dp"
                                android:layout_columnWeight="1"
                                android:text="Waitlist"
                                android:textSize="13sp"
                                android:checkable="true"
                                android:checked="true"

                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipSelected"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_marginBottom="8dp"
                                android:layout_columnWeight="1"
                                android:text="Selected"
                                android:textSize="13sp"
                                android:checkable="true"
                                android:checked="false"

                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipCancelled"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="4dp"
                                android:layout_columnWeight="1"
                                android:text="Cancelled"
                                android:textSize="13sp"
                                android:checkable="true"
                                android:checked="true"

                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipAll"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:layout_columnWeight="1"
                                android:text="All entrants"
                                android:textSize="13sp"
                                android:checkable="true"
                                android:checked="false"

                                app:chipStrokeWidth="1.5dp"
                                app:checkedIconVisible="false" />

                        </GridLayout>

                        <TextView
                            android:id="@+id/recipientCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="2 groups selected"
                            android:textColor="#2ECC71"
                            android:textSize="11sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Message card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/messageCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="14dp"
                    android:alpha="0"
                    tools:alpha="1"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <!-- Title box -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Title"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintTextColor="#BBBBBB">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/titleInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="30dp"
                                android:hint="Enter title..."
                                android:maxLines="1"
                                android:inputType="text"
                                android:gravity="top"
                                android:maxLength="50"
                                android:imeOptions="actionDone"
                                />

                        </com.google.android.material.textfield.TextInputLayout>
                        <TextView
                            android:id="@+id/titleCharCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="6dp"
                            android:text="0 / 50"
                            android:textColor="#BBBBBB"
                            android:textSize="11sp" />
                        <!--Message Input box -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MESSAGE"
                            android:textColor="#888888"
                            android:textSize="11sp"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="10dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:hintTextColor="#BBBBBB">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/messageInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="72dp"
                                android:hint="Type your message..."
                                android:inputType="textMultiLine"
                                android:gravity="top"
                                android:maxLength="500" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/charCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="6dp"
                            android:text="0 / 500"
                            android:textColor="#BBBBBB"
                            android:textSize="11sp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- invite co_organizer -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/coOrganizerInviteButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="#2ECC71"
                    android:text="Invite Co-organizer"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />

                <!-- Send button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="14dp"
                    android:backgroundTint="#2ECC71"
                    android:text="Send notification"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp" />



            </LinearLayout>
        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>